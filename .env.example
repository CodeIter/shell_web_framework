
BASH_HOST="127.0.0.1"
BASH_PORT="8080"
PUBLIC_DOMAIN="${KOYEB_PUBLIC_DOMAIN:-${BASH_HOST}:${BASH_PORT}}"

SESSION_DIR="sessions"
SESSION_TTL="86400" # 1 day

SESSION_SECRET="change-this-secret-in-env"

UPLOAD_DIR="tmp/uploads"
UPLOAD_MAX_SIZE="10485760" # 10 MiB
MAX_BODY="10551296"        # keep request body limit >= upload limit

SHORTENER_DATA_DIR="data"
SHORTENER_DB_FILE="${SHORTENER_DATA_DIR}/url_shortener.db"
SHORTENER_PUBLIC_BASE_URL="http://${PUBLIC_DOMAIN}"

